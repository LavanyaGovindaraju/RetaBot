# OpenAI API Key (required)
OPENAI_API_KEY=sk-your-api-key-here

# LLM settings
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.7

# Speech settings
TTS_ENABLED=true
TTS_VOICE=en-US-JennyNeural
STT_ENABLED=true

# RAG settings
RAG_ENABLED=true
RAG_TOP_K=3
EMBEDDING_MODEL=text-embedding-3-small

# Agent customization
AGENT_NAME=TechMart Support
COMPANY_NAME=TechMart
